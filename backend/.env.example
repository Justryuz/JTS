# TrustGuard v2.0 — Environment Configuration
# Copy this file to .env and fill in the values.
# NEVER commit .env to git.

# ── REQUIRED ──────────────────────────────────────────────────────────────────
# Generate with: python -c "import secrets; print(secrets.token_hex(32))"
JWT_SECRET=your-strong-random-secret-minimum-32-chars

# ── DATABASE ──────────────────────────────────────────────────────────────────
# SQLite (default)
DATABASE_URL=sqlite:///./storage/database/aisec.db
# PostgreSQL (production)
# DATABASE_URL=postgresql://user:password@localhost:5432/trustguard

# ── APPLICATION ───────────────────────────────────────────────────────────────
ENVIRONMENT=production
DEBUG=false
APP_VERSION=2.0.0

# ── JWT ───────────────────────────────────────────────────────────────────────
JWT_ACCESS_EXPIRE_MINUTES=60
JWT_REFRESH_EXPIRE_DAYS=7

# ── CORS ──────────────────────────────────────────────────────────────────────
# Comma-separated list of allowed origins
CORS_ORIGINS=["http://localhost:8000"]

# ── RATE LIMITING ─────────────────────────────────────────────────────────────
SHIELD_RATE_LIMIT_PER_MINUTE=100
AUTH_RATE_LIMIT_PER_MINUTE=10
SCAN_RATE_LIMIT_PER_MINUTE=20

# ── ML ENGINE ─────────────────────────────────────────────────────────────────
INJECTION_THRESHOLD=0.75
TOXIC_THRESHOLD=0.80

# ── SCAN LIMITS ───────────────────────────────────────────────────────────────
MAX_REPO_SIZE_MB=200
MAX_FILES=500
SCAN_TIMEOUT_SECONDS=60
MAX_UPLOAD_MB=200
MAX_PROMPT_LENGTH=10000
